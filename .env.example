# =============================================================================
# Maawa — Environment variables
# =============================================================================
# Copy this file to .env.local and fill in real values for development.
# In production, set these via your hosting provider (Vercel / Cloud Run /
# Docker / etc.) — never commit real values.
#
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser. All
# others are server-only and never sent to the client.
# =============================================================================

# -----------------------------------------------------------------------------
# Firebase — public client config (browser-safe; restrict by HTTP referrer in
# Google Cloud Console > Credentials)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# -----------------------------------------------------------------------------
# Firebase Admin SDK — server-only, NEVER expose to client
# Generate via: Firebase Console > Project Settings > Service Accounts >
# Generate new private key. Copy the three values from the downloaded JSON.
# Note: FIREBASE_ADMIN_PRIVATE_KEY must be wrapped in double quotes and
# preserve `\n` literals (the env loader unescapes them at runtime).
# -----------------------------------------------------------------------------
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# -----------------------------------------------------------------------------
# Google Maps — public, browser-safe; restrict by HTTP referrer + API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# -----------------------------------------------------------------------------
# Twilio — server-only, used for OTP verification
# https://www.twilio.com/console
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# -----------------------------------------------------------------------------
# Auth session signing — generate via:  openssl rand -base64 32
# -----------------------------------------------------------------------------
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Sentry — error tracking. Get DSN from sentry.io
# Both names point to the same DSN; the NEXT_PUBLIC_ one is exposed to the
# browser bundle for client-side error capture.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# -----------------------------------------------------------------------------
# Feature flags — defaults to "off" if unset
# -----------------------------------------------------------------------------
# Enables the /seed/* admin tooling routes. Leave unset/false in production.
ENABLE_SEED_ROUTES=false

# Enables verbose request logging. Leave unset/false in production unless
# debugging an incident.
ENABLE_DEBUG_LOGS=false

# -----------------------------------------------------------------------------
# Admin bootstrap — used by `npm run admin:bootstrap` to create the FIRST
# super-admin account when standing up a new environment. Once the admin
# exists, unset these. Format: comma-separated list of UIDs.
# -----------------------------------------------------------------------------
BOOTSTRAP_ADMIN_UIDS=

# -----------------------------------------------------------------------------
# App configuration — runtime constants
# -----------------------------------------------------------------------------
# Public app URL (no trailing slash). Used for absolute links in emails / SMS.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Customer support phone — displayed in "Call Maawa" buttons (E.164 format).
NEXT_PUBLIC_SUPPORT_PHONE=+213233000000

# Maawa Coin → DZD conversion rate (e.g. 50 means 1 MC = 50 DZD).
NEXT_PUBLIC_MC_RATE_DZD=50

# Platform commission rate (decimal, e.g. 0.10 = 10%).
PLATFORM_COMMISSION_RATE=0.10

# -----------------------------------------------------------------------------
# Coin-purchase ("demande de recharge") — payment instructions shown to users
# AFTER they submit a request. The operator fills these per environment.
# All three are optional; a blank value hides that method from the modal.
# -----------------------------------------------------------------------------
# CCP account (Compte Courant Postal) — typically "XXXX XX XX clé XX".
NEXT_PUBLIC_CCP_NUMBER=

# Baridimob recipient — usually a phone number or RIP.
NEXT_PUBLIC_BARIDIMOB_NUMBER=

# Physical address of the Maawa office for cash payments.
NEXT_PUBLIC_OFFICE_ADDRESS=
